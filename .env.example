# SQLite (local dev uses ./data/rental.db; Docker uses /app/data/rental.db)
DATABASE_URL=file:./data/rental.db

# Gmail OAuth (Google Cloud Console → Gmail API enabled)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_REDIRECT_URI=http://localhost:3000/oauth2callback

# Optional: mark processed bank emails as read
GMAIL_MARK_READ=true

# Days without payment before "overdue" badge (balance > 0)
OVERDUE_DAYS=35

# Cron expression for background Gmail sync (default: every 5 minutes)
GMAIL_SYNC_CRON=*/5 * * * *

# Initial backfill window when no prior sync (days)
GMAIL_BACKFILL_DAYS=90
